%.o	Makefile	/^%.o: %.c$/;"	kind:t	line:24
%.o	Makefile	/^%.o: %.s$/;"	kind:t	line:27
AS	Makefile	/^AS	= nasm$/;"	kind:m	line:3
ASFLAGS	Makefile	/^ASFLAGS	=	-f elf32$/;"	kind:m	line:10
CC	Makefile	/^CC	= i686-elf-gcc$/;"	kind:m	line:2
CFLAGS	Makefile	/^CFLAGS	=	-m32 -nostdlib -fno-builtin -fno-stack-protector \\$/;"	kind:m	line:6
CHECKSUM	loader.s	/^CHECKSUM		equ -MAGIC_NUMBER				; calculate the checksum $/;"	kind:d	line:5
Debug	README.md	/^## Debug$/;"	kind:s	line:15	chapter:KernuOS
FLAGS	loader.s	/^FLAGS			equ 0x0							; multiboot flags $/;"	kind:d	line:4
KERNEL_STACK_SIZE	loader.s	/^KERNEL_STACK_SIZE	equ 4096						; size of stack in bytes$/;"	kind:d	line:8
KernuOS	README.md	/^# KernuOS$/;"	kind:c	line:1
KernuOS.iso	Makefile	/^KernuOS.iso: Kernel.elf$/;"	kind:t	line:17
LD	Makefile	/^LD	= i686-elf-ld$/;"	kind:m	line:1
LDFLAGS	Makefile	/^LDFLAGS	=	-T link.ld -melf_i386$/;"	kind:m	line:9
MAGIC_NUMBER	loader.s	/^MAGIC_NUMBER	equ 0x1BADB002					; define the magic number constant$/;"	kind:d	line:3
OBJECTS	Makefile	/^OBJECTS	=	loader.o kmain.o$/;"	kind:m	line:5
Run	README.md	/^## Run$/;"	kind:s	line:9	chapter:KernuOS
all	Makefile	/^all: kernel.elf$/;"	kind:t	line:12
clean	Makefile	/^clean: $/;"	kind:t	line:30
kernel.elf	Makefile	/^kernel.elf: $(OBJECTS)$/;"	kind:t	line:14
kernel_stack	loader.s	/^kernel_stack:									; label points to beginning of memory$/;"	kind:l	line:12
kmain	kmain.c	/^void kmain(void){$/;"	kind:f	line:1	typeref:typename:void	signature:(void)
loader	loader.s	/^loader:											; the loader label (defined as entry point in linker script)$/;"	kind:l	line:21
loop	loader.s	/^.loop:$/;"	kind:l	line:25
run	Makefile	/^run: KernuOS.iso$/;"	kind:t	line:21
